# Firebase Configuration Template
# Copy this file to .env and replace with your actual Firebase credentials
# Get these from: Firebase Console > Project Settings > General > Your apps

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional: Set to 'true' to use Firebase emulators in development
# VITE_USE_EMULATORS=false

# Sentry Configuration (Error Monitoring)
# Get your DSN from: https://sentry.io/settings/projects/your-project/keys/
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Application Version (for Sentry releases)
# VITE_APP_VERSION=1.0.0
